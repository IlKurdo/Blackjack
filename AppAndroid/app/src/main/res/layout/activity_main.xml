<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A5D6A7"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Blackjack Android"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--- CARTE BANCO ---"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvCarteBanco"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="?"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvRisultato"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inizia partita!"
        android:textSize="20sp"
        android:textColor="#D32F2F"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--- LE TUE CARTE ---"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvCarteGiocatore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="16sp"
        android:layout_marginBottom="30dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnPesca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pesca Carta"
            android:layout_margin="5dp"/>

        <Button
            android:id="@+id/btnStai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stai e Passa"
            android:layout_margin="5dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnNuova"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuova Partita"
        android:layout_margin="5dp"/>

</LinearLayout>
